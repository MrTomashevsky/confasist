# '

export NEWT_COLORS='
    root=black,green
    roottext=black,green


    window=black,lightgray
    title=black,lightgray
    border=black,lightgray


    textbox=black,lightgray



    listbox=black,lightgray
    actsellistbox=black,green
    actlistbox=black,white

    compactbutton=black,lightgray

    button=white,green,
    checkbox=black,green
    actcheckbox=green,black
'

#
# label=,green
# border=white,red
# textbox=white,red
# button=black,white

if [[ "${1:-}" == "-r" ]]; then
    shift
    run_cli "$@"
    exit 0
fi

if [[ "${1:-}" == "--new" ]]; then
    shift

    SCRIPT_NAME="$1"
    shift

    DESCRIPTION=""
    DISTROS=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --desc)
                DESCRIPTION="$2"
                shift 2
                ;;

            --distros)
                DISTROS="$2"
                shift 2
                ;;
            --help)
		less README.md
		exit 0
		;;
            *)
                shift
                ;;
        esac
    done

    create_new_script "$SCRIPT_NAME" "$DESCRIPTION" "$DISTROS"
    exit 0
fi

show_directory_menu "$APP_DIR"
